{
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/static-proxy",
      "has": [
        {
          "type": "host",
          "value": "(?!www\\.customwebsitesplus\\.com|customwebsitesplus\\.com|.*\\.vercel\\.app).*"
        }
      ]
    },
    {
      "source": "/((?!robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ]
}
